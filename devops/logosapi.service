[Unit]
Description=Logos API for Healthcare platform application

[Service]
WorkingDirectory=/var/www/logos/net9.0
ExecStart=/usr/bin/dotnet /var/www/logos/net9.0/LogosAPI.dll
Restart=always
# Restart service after 10 seconds if the dotnet service crashes:
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=logos-api
User=logos-api
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_NOLOGO=true

[Install]
WantedBy=multi-user.target
